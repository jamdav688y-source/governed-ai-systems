{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Target State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target_id",
    "target_name",
    "target_type",
    "current_stage",
    "signal_score",
    "constraint_detected",
    "authority_gap",
    "conversion_readiness",
    "response_type",
    "assigned_agent",
    "next_action",
    "state_version",
    "last_updated"
  ],
  "properties": {
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "target_name": {
      "type": "string",
      "minLength": 1
    },
    "target_type": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "current_stage": {
      "type": "string",
      "enum": ["ENTRY", "PROBE", "CLASSIFY", "ESCALATE", "CONVERT", "EXIT"]
    },
    "signal_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "constraint_detected": {
      "type": "string"
    },
    "authority_gap": {
      "type": "string"
    },
    "conversion_readiness": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "response_type": {
      "type": "string",
      "enum": [
        "ownership",
        "curiosity",
        "defense",
        "peer_alignment",
        "strategic_founder",
        "constraint_acknowledgement",
        "conversion_interest",
        "noise",
        "none"
      ]
    },
    "assigned_agent": {
      "type": "string",
      "enum": [
        "signal_hunter",
        "constraint_mapper",
        "classifier_engine",
        "dialogue_executor",
        "pressure_injector",
        "conversion_engine",
        "architect_intelligence",
        "cross_thread_synthesizer",
        "authority_core"
      ]
    },
    "next_action": {
      "type": "string",
      "enum": [
        "push",
        "hold",
        "convert",
        "align",
        "shape",
        "destabilize",
        "filter",
        "drop",
        "exit"
      ]
    },
    "ownership_signal_detected": {
      "type": "boolean",
      "default": false
    },
    "uncertainty_signal_detected": {
      "type": "boolean",
      "default": false
    },
    "boundary_exposure_detected": {
      "type": "boolean",
      "default": false
    },
    "classification_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "pressure_ceiling": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "thread_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_platform": {
          "type": "string",
          "enum": ["linkedin", "email", "github", "chat", "manual"]
        },
        "thread_id": {
          "type": "string"
        },
        "last_message_id": {
          "type": "string"
        },
        "message_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp", "stage", "action"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "stage": {
            "type": "string",
            "enum": ["ENTRY", "PROBE", "CLASSIFY", "ESCALATE", "CONVERT", "EXIT"]
          },
          "action": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "state_version": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  }
}